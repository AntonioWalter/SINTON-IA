   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Orari Attivi (Night Owls Adjustment)\n",
    "Il GA Ã¨ in grado di evitare gli orari notturni (dalle 23 alle 6), tranne nel caso in cui l'utente sia un 'Night Owl'."
   ],
   "id": "cd94e648f8f4bc2e"
  },
  {
   "cell_type": "code",
   "metadata": {
    "ExecuteTime": {
     "end_time": "2026-03-11T13:42:55.962375200Z",
     "start_time": "2026-03-11T13:42:54.911956300Z"
    }
   },
   "source": [
    "# Estraiamo tutti gli orari attivi dalle migliori strategie del benchmark\n",
    "all_hours = []\n",
    "for _, row in df_bench.iterrows():\n",
    "    patient = df[df['id_paziente'] == row['id_paziente']].iloc[0]\n",
    "    ga_h = GeneticAlgorithm(GAParams(pop_size=20, generations=20), patient)\n",
    "    opts = ga_h.run().decode()\n",
    "    all_hours.extend(opts['orari_attivi'])\n",
    "\n",
    "plt.figure(figsize=(10, 5))\n",
    "sns.histplot(all_hours, bins=range(25), discrete=True, color=\"coral\")\n",
    "plt.axvspan(23, 24, color='gray', alpha=0.3, label='Orario Notturno')\n",
    "plt.axvspan(0, 6, color='gray', alpha=0.3)\n",
    "plt.title(\"Distribuzione degli Orari di Notifica Scelti dal GA\\n(Evitamento fascia notturna)\", fontsize=14)\n",
    "plt.xlabel(\"Ora del Giorno (0-23)\")\n",
    "plt.ylabel(\"Frequenza di Scelta\")\n",
    "plt.xticks(range(24))\n",
    "plt.legend()\n",
    "\n",
    "plt.savefig(os.path.join(FIGURES_DIR, '05_ga_time_distribution.png'), bbox_inches='tight', dpi=300)\n",
    "plt.show()"
   ],

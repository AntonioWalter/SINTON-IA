    "## 1. Caricamento Dati"
   ],
   "id": "db03b814e98e9ea1"
  },
  {
   "cell_type": "code",
   "metadata": {
    "ExecuteTime": {
     "end_time": "2026-03-11T13:42:49.821836100Z",
     "start_time": "2026-03-11T13:42:49.574275800Z"
    }
   },
   "source": [
    "data_path = os.path.join(os.getcwd(), '..', 'data', 'processed', 'churn_features.csv')\n",
    "\n",
    "if not os.path.exists(data_path):\n",
    "    raise FileNotFoundError(f\"Dataset non trovato in {data_path}. Eseguire prima '../src/aggregate_features.py'\")\n",
    "\n",
    "df = pd.read_csv(data_path)\n",
    "print(f\"Dataset caricato: {df.shape[0]} pazienti.\")\n",
    "\n",
    "plt.figure(figsize=(8, 5))\n",
    "ax = sns.countplot(data=df, x='profilo_assegnato', order=['Engaged', 'Moderato', 'A Rischio', 'Ghost'], hue='profilo_assegnato', legend=False, palette=\"viridis\")\n",
    "plt.title(\"Distribuzione dei Profili Utente\", fontsize=14)\n",
    "plt.ylabel(\"Numero di Pazienti\")\n",
    "plt.xlabel(\"Profilo\")\n",
    "for p in ax.patches:\n",
    "    ax.annotate(f'{p.get_height()}', (p.get_x() + p.get_width() / 2., p.get_height()), ha='center', va='bottom')\n",
    "\n",
    "plt.savefig(os.path.join(FIGURES_DIR, '05_churn_profiles_dist.png'), bbox_inches='tight', dpi=300)\n",
    "plt.show()"
   ],

   "source": [
    "## 3. Analisi Fenotipica per Profilo (Strategie a confronto)\n",
    "Come varia la strategia ottima in base al profilo del paziente?"
   ],
   "id": "bc9e5293598f463a"
  },
  {
   "cell_type": "code",
   "metadata": {
    "ExecuteTime": {
     "end_time": "2026-03-11T13:42:52.647657300Z",
     "start_time": "2026-03-11T13:42:50.348838200Z"
    }
   },
   "source": [
    "n_samples = 15 # Campioni per profilo\n",
    "profiles = ['Engaged', 'Moderato', 'A Rischio', 'Ghost']\n",
    "phenotype_results = []\n",
    "\n",
    "print(\"Esecuzione GA per analisi fenotipica sui profili...\")\n",
    "for p in profiles:\n",
    "    sample_df = df[df['profilo_assegnato'] == p].sample(n_samples)\n",
    "    for _, row in sample_df.iterrows():\n",
    "        ga_prof = GeneticAlgorithm(GAParams(pop_size=50, generations=40), pd.Series(row))\n",
    "        best = ga_prof.run()\n",
    "        ptype = best.decode()\n",
    "        phenotype_results.append({\n",
    "            'Profilo': p,\n",
    "            'Frequenza': ptype['frequenza_settimanale'],\n",
    "            'Tipologia': ptype['tipologia']\n",
    "        })\n",
    "\n",
    "res_df = pd.DataFrame(phenotype_results)\n",
    "\n",
    "fig, ax = plt.subplots(1, 2, figsize=(14, 6))\n",
    "\n",
    "sns.boxplot(data=res_df, x='Profilo', y='Frequenza', ax=ax[0], hue='Profilo', legend=False, palette=\"Set2\", order=profiles)\n",
    "ax[0].set_title(\"Frequenza Settimanale Suggerita per Profilo\")\n",
    "ax[0].set_ylabel(\"N. Notifiche a Settimana\")\n",
    "\n",
    "sns.histplot(data=res_df, x='Profilo', hue='Tipologia', multiple=\"fill\", shrink=.8, ax=ax[1], legend=False, palette=\"Paired\")\n",
    "ax[1].set_title(\"Proporzione Tipologia Notifiche per Profilo\")\n",
    "ax[1].set_ylabel(\"Proporzione\")\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig(os.path.join(FIGURES_DIR, '05_ga_phenotype_analysis.png'), bbox_inches='tight', dpi=300)\n",
    "plt.show()"
   ],

   "source": [
    "## 2. Evoluzione Singola: Convergenza e DiversitÃ  Genetica\n",
    "Eseguiamo l'Algoritmo Genetico per un singolo utente con profilo 'Ghost'."
   ],
   "id": "9350f73ada3cc00a"
  },
  {
   "cell_type": "code",
   "metadata": {
    "ExecuteTime": {
     "end_time": "2026-03-11T13:42:50.328405200Z",
     "start_time": "2026-03-11T13:42:49.824263800Z"
    }
   },
   "source": [
    "# Selezioniamo il primo paziente 'Ghost'\n",
    "patient_row = df[df['profilo_assegnato'] == 'Ghost'].iloc[0]\n",
    "patient = pd.Series(patient_row)\n",
    "\n",
    "params = GAParams(pop_size=50, generations=80)\n",
    "ga = GeneticAlgorithm(params, patient)\n",
    "\n",
    "print(\"Avvio evoluzione...\")\n",
    "start_time = time.time()\n",
    "best_strategy = ga.run()\n",
    "exec_time = time.time() - start_time\n",
    "print(f\"Evoluzione terminata in {exec_time:.3f} secondi.\")\n",
    "\n",
    "print(\"\\n--- Strategia Ottimale Trovata ---\")\n",
    "print(f\"Fitness: {best_strategy.fitness:.4f}\")\n",
    "phenotype = best_strategy.decode()\n",
    "for k, v in phenotype.items():\n",
    "    print(f\"{k}: {v}\")\n",
    "\n",
    "# PLOT: Convergenza vs Diversità\n",
    "fig, ax1 = plt.subplots(figsize=(10, 6))\n",
    "\n",
    "color = 'tab:blue'\n",
    "ax1.set_xlabel('Generazioni')\n",
    "ax1.set_ylabel('Fitness (Best & Avg)', color=color)\n",
    "ax1.plot(ga.history_best, label='Best Fitness', color='blue', linewidth=2)\n",
    "ax1.plot(ga.history_avg, label='Average Fitness', color='lightblue', linewidth=2, linestyle='--')\n",
    "ax1.tick_params(axis='y', labelcolor=color)\n",
    "ax1.legend(loc='lower left')\n",
    "\n",
    "ax2 = ax1.twinx()  \n",
    "color = 'tab:red'\n",
    "ax2.set_ylabel('Diversità Genetica', color=color)\n",
    "ax2.plot(ga.history_diversity, label='Genetic Diversity', color=color, linewidth=2)\n",
    "ax2.tick_params(axis='y', labelcolor=color)\n",
    "ax2.legend(loc='lower right')\n",
    "\n",
    "plt.title(\"Convergenza del GA e Diversità Genetica per Utente 'Ghost'\", fontsize=14)\n",
    "fig.tight_layout()\n",
    "plt.savefig(os.path.join(FIGURES_DIR, '05_ga_convergence_diversity.png'), bbox_inches='tight', dpi=300)\n",
    "plt.show()"
   ],

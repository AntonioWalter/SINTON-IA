    "## 6. Sensitivity Analysis & ScalabilitÃ \n",
    "Analizziamo come una variazione pesante del parametro `w_penalty_freq` impatti la frequenza scelta, e riportiamo i tempi di calcolo per l'inserimento in produzione."
   ],
   "id": "20dc9a8e2bad267f"
  },
  {
   "cell_type": "code",
   "metadata": {
    "ExecuteTime": {
     "end_time": "2026-03-11T13:42:56.246324100Z",
     "start_time": "2026-03-11T13:42:55.983103500Z"
    }
   },
   "source": [
    "patient_sa = df[df['profilo_assegnato'] == 'Moderato'].iloc[0]\n",
    "weights = [0.0, 0.2, 0.5, 0.8, 1.0, 1.5, 2.0]\n",
    "freqs_sa = []\n",
    "\n",
    "print(\"Esecuzione Sensitivity Analysis...\")\n",
    "start_batch = time.time()\n",
    "for w in weights:\n",
    "    p = GAParams(pop_size=30, generations=30, w_penalty_freq=w)\n",
    "    ga_sa = GeneticAlgorithm(p, patient_sa)\n",
    "    best = ga_sa.run()\n",
    "    freqs_sa.append(best.decode()['frequenza_settimanale'])\n",
    "\n",
    "batch_time = (time.time() - start_batch) / len(weights)\n",
    "print(f\"\\nTempo medio esecuzione per GA (30 pop, 30 gen): {batch_time*1000:.2f} ms per paziente.\")\n",
    "\n",
    "plt.figure(figsize=(8, 4))\n",
    "plt.plot(weights, freqs_sa, marker='o', linestyle='-', color='teal')\n",
    "plt.title(\"Impatto del peso w_penalty_freq sulla Frequenza Ottima (Profilo Moderato)\")\n",
    "plt.xlabel(\"Peso w_penalty_freq\")\n",
    "plt.ylabel(\"Frequenza Settimanale\")\n",
    "plt.ylim(0, 32)\n",
    "plt.show()"
   ],

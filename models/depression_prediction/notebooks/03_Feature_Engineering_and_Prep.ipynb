    "      \"✅ Feature Engineering completato!\\n\",\n",
    "      \"   Pazienti processati: 100,000\\n\",\n",
    "      \"   Pazienti scartati (dati insufficienti): 0\\n\",\n",
    "      \"\\n\",\n",
    "      \"Shape della matrice features: (100000, 11)\\n\"\n",
    "     ]\n",
    "    }\n",
    "   ],\n",
    "   \"source\": [\n",
    "    \"print(\\\"🔧 Estrazione features in corso...\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"features_list = []\\n\",\n",
    "    \"skipped = 0\\n\",\n",
    "    \"\\n\",\n",
    "    \"for pid, group in df.groupby('patient_id'):\\n\",\n",
    "    \"    feat = extract_features(group)\\n\",\n",
    "    \"    if feat is not None:\\n\",\n",
    "    \"        features_list.append(feat)\\n\",\n",
    "    \"    else:\\n\",\n",
    "    \"        skipped += 1\\n\",\n",
    "    \"\\n\",\n",
    "    \"features_df = pd.DataFrame(features_list)\\n\",\n",
    "    \"print(f\\\"\\\\n✅ Feature Engineering completato!\\\")\\n\",\n",
    "    \"print(f\\\"   Pazienti processati: {len(features_df):,}\\\")\\n\",\n",
    "    \"print(f\\\"   Pazienti scartati (dati insufficienti): {skipped:,}\\\")\\n\",\n",
    "    \"print(f\\\"\\\\nShape della matrice features: {features_df.shape}\\\")\"\n",
    "   ]\n",

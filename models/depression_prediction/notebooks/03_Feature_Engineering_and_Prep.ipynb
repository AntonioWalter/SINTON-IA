    "     \"text\": [\n",
    "      \"Dataset caricato: 1,400,000 righe × 10 colonne\\n\",\n",
    "      \"Pazienti: 100,000\\n\",\n",
    "      \"Missing records: 147,777 (10.6%)\\n\",\n",
    "      \"\\n\",\n",
    "      \"✅ Dati pronti per il Feature Engineering\\n\"\n",
    "     ]\n",
    "    }\n",
    "   ],\n",
    "   \"source\": [\n",
    "    \"import os\\n\",\n",
    "    \"import json\\n\",\n",
    "    \"import warnings\\n\",\n",
    "    \"\\n\",\n",
    "    \"import numpy as np\\n\",\n",
    "    \"import pandas as pd\\n\",\n",
    "    \"import matplotlib\\n\",\n",
    "    \"matplotlib.use('Agg')\\n\",\n",
    "    \"import matplotlib.pyplot as plt\\n\",\n",
    "    \"import seaborn as sns\\n\",\n",
    "    \"from sklearn.preprocessing import StandardScaler\\n\",\n",
    "    \"\\n\",\n",
    "    \"warnings.filterwarnings('ignore')\\n\",\n",
    "    \"sns.set_style('whitegrid')\\n\",\n",
    "    \"plt.rcParams['figure.figsize'] = (14, 6)\\n\",\n",
    "    \"\\n\",\n",
    "    \"RAW_DIR = os.path.join('..', 'data', 'raw')\\n\",\n",
    "    \"PROCESSED_DIR = os.path.join('..', 'data', 'processed')\\n\",\n",
    "    \"FIGURES_DIR = os.path.join('..', '..', '..', 'docs', 'latex', 'figures')\\n\",\n",
    "    \"os.makedirs(FIGURES_DIR, exist_ok=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Caricamento dataset sintetico dal Notebook 02\\n\",\n",
    "    \"df = pd.read_csv(os.path.join(RAW_DIR, 'synthetic_depression_data_v2.csv'))\\n\",\n",
    "    \"print(f\\\"Dataset caricato: {df.shape[0]:,} righe × {df.shape[1]} colonne\\\")\\n\",\n",
    "    \"print(f\\\"Pazienti: {df['patient_id'].nunique():,}\\\")\\n\",\n",
    "    \"print(f\\\"Missing records: {df['is_missing'].sum():,} ({df['is_missing'].mean()*100:.1f}%)\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Caricamento mappa V-A\\n\",\n",
    "    \"with open(os.path.join(RAW_DIR, 'statistical_patterns.json'), 'r', encoding='utf-8') as f:\\n\",\n",
    "    \"    patterns = json.load(f)\\n\",\n",
    "    \"VA_MAP = patterns['sintonia_valence_arousal_map']\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"\\\\n✅ Dati pronti per il Feature Engineering\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"id\": \"da7e8571\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"---\\n\",\n",
    "    \"## 2. Feature Engineering\\n\",\n",
    "    \"\\n\",\n",
    "    \"### Filosofia\\n\",\n",
    "    \"Le features devono catturare **pattern temporali** e **dinamiche emotive**\\n\",\n",
    "    \"che la letteratura scientifica associa alla depressione:\\n\",\n",
    "    \"- **Tono medio basso** (Kuppens et al., 2010)\\n\",\n",
    "    \"- **Alta instabilità emotiva** (Houben et al., 2015)\\n\",\n",
    "    \"- **Trend discendente** (Wichers et al., 2016)\\n\",\n",
    "    \"- **Streak negative prolungate** (aan het Rot et al., 2012)\\n\",\n",
    "    \"- **Mancata risposta ai check-in** (Mohr et al., 2017)\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": 2,\n",
    "   \"id\": \"2d1d2e16\",\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-03-11T21:13:25.378644600Z\",\n",
    "     \"start_time\": \"2026-03-11T21:13:25.311239500Z\"\n",
    "    },\n",
    "    \"execution\": {\n",
    "     \"iopub.execute_input\": \"2026-03-18T10:09:28.923803Z\",\n",
    "     \"iopub.status.busy\": \"2026-03-18T10:09:28.923158Z\",\n",
    "     \"iopub.status.idle\": \"2026-03-18T10:09:28.936739Z\",\n",
    "     \"shell.execute_reply\": \"2026-03-18T10:09:28.935231Z\"\n",
    "    },\n",
    "    \"lines_to_next_cell\": 1\n",
    "   },\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"def extract_features(patient_data):\\n\",\n",
    "    \"    \\\"\\\"\\\"Estrae un vettore di 8 features da 14 giorni di check-in emotivi.\\\"\\\"\\\"\\n\",\n",
    "    \"    pid = patient_data['patient_id'].iloc[0]\\n\",\n",
    "    \"    phq9 = patient_data['phq9_total'].iloc[0]\\n\",\n",
    "    \"    severity = patient_data['severity'].iloc[0]\\n\",\n",
    "    \"\\n\",\n",
    "    \"    present = patient_data[~patient_data['is_missing']]\\n\",\n",
    "    \"    n_total = len(patient_data)\\n\",\n",
    "    \"    n_present = len(present)\\n\",\n",
    "    \"    n_missing = n_total - n_present\\n\",\n",
    "    \"\\n\",\n",
    "    \"    if n_present < 3:\\n\",\n",
    "    \"        return None\\n\",\n",
    "    \"\\n\",\n",
    "    \"    valences = present['valence'].values\\n\",\n",
    "    \"    intensities = present['intensity'].values\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Feature 1: Valence Media\\n\",\n",
    "    \"    valence_mean = np.mean(valences)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Feature 2: Volatilità Emotiva (Houben et al., 2015)\\n\",\n",
    "    \"    valence_std = np.std(valences) if n_present > 1 else 0.0\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Feature 3: EMA ultimi 3 punti (recency bias)\\n\",\n",
    "    \"    alpha = 2 / (3 + 1)\\n\",\n",
    "    \"    ema = valences[0]\\n\",\n",
    "    \"    for v in valences[1:]:\\n\",\n",
    "    \"        ema = alpha * v + (1 - alpha) * ema\\n\",\n",
    "    \"    valence_ema_3d = ema\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Feature 4: Trend ultimi 5 punti (Wichers et al., 2016)\\n\",\n",
    "    \"    if n_present >= 5:\\n\",\n",
    "    \"        last5 = valences[-5:]\\n\",\n",
    "    \"        x = np.arange(len(last5))\\n\",\n",
    "    \"        slope, _ = np.polyfit(x, last5, 1)\\n\",\n",
    "    \"        valence_trend_5d = slope\\n\",\n",
    "    \"    elif n_present >= 2:\\n\",\n",
    "    \"        x = np.arange(n_present)\\n\",\n",
    "    \"        slope, _ = np.polyfit(x, valences, 1)\\n\",\n",
    "    \"        valence_trend_5d = slope\\n\",\n",
    "    \"    else:\\n\",\n",
    "    \"        valence_trend_5d = 0.0\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Feature 5: Max Streak Negativa (aan het Rot et al., 2012)\\n\",\n",
    "    \"    max_neg = 0\\n\",\n",
    "    \"    current_neg = 0\\n\",\n",
    "    \"    for is_missing, valence in zip(patient_data['is_missing'].values,\\n\",\n",
    "    \"                                    patient_data['valence'].values):\\n\",\n",
    "    \"        if not is_missing and valence < 0:\\n\",\n",
    "    \"            current_neg += 1\\n\",\n",
    "    \"            max_neg = max(max_neg, current_neg)\\n\",\n",
    "    \"        elif not is_missing:\\n\",\n",
    "    \"            current_neg = 0\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Feature 6: Missing Ratio (Mohr et al., 2017)\\n\",\n",
    "    \"    missing_ratio = n_missing / n_total\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Feature 7: Intensità Media (Rottenberg et al., 2005)\\n\",\n",
    "    \"    intensity_mean = np.mean(intensities)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Feature 8: Stato Dominante (Russell, 1980)\\n\",\n",
    "    \"    mood_counts = present['mood_state'].value_counts()\\n\",\n",
    "    \"    dominant_mood = mood_counts.index[0] if len(mood_counts) > 0 else 'Neutro'\\n\",\n",
    "    \"    dominant_mood_valence = VA_MAP.get(dominant_mood, {'valence': 0})['valence']\\n\",\n",
    "    \"\\n\",\n",
    "    \"    return {\\n\",\n",
    "    \"        'patient_id': pid,\\n\",\n",
    "    \"        'valence_mean': round(valence_mean, 6),\\n\",\n",
    "    \"        'valence_std': round(valence_std, 6),\\n\",\n",
    "    \"        'valence_ema_3d': round(valence_ema_3d, 6),\\n\",\n",
    "    \"        'valence_trend_5d': round(valence_trend_5d, 6),\\n\",\n",
    "    \"        'max_neg_streak': int(max_neg),\\n\",\n",
    "    \"        'missing_ratio': round(missing_ratio, 6),\\n\",\n",
    "    \"        'intensity_mean': round(intensity_mean, 6),\\n\",\n",
    "    \"        'dominant_mood_valence': round(dominant_mood_valence, 6),\\n\",\n",
    "    \"        'phq9_total': int(phq9),\\n\",\n",
    "    \"        'severity': severity\\n\",\n",
    "    \"    }\"\n",
    "   ]\n",
    "  },\n",

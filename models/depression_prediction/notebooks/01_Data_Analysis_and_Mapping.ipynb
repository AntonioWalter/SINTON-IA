    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-03-11T20:21:10.564616100Z\",\n",
    "     \"start_time\": \"2026-03-11T20:21:10.331714Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"# ═══════════════════════════════════════════════════════════════\\n\",\n",
    "    \"# 5.1  DISTRIBUZIONE VALENCE PER FASCIA PHQ-9\\n\",\n",
    "    \"# ═══════════════════════════════════════════════════════════════\\n\",\n",
    "    \"stats_by_severity = {}\\n\",\n",
    "    \"\\n\",\n",
    "    \"severities = ['Minima (0-4)', 'Lieve (5-9)', 'Moderata (10-14)', 'Mod. Severa (15-19)', 'Severa (20-27)']\\n\",\n",
    "    \"\\n\",\n",
    "    \"for sev in severities:\\n\",\n",
    "    \"    subset = df14[df14['severity'] == sev]\\n\",\n",
    "    \"    if len(subset) > 0:\\n\",\n",
    "    \"        stats_by_severity[sev] = {\\n\",\n",
    "    \"            'n_patients': int(subset['user_id'].nunique()),\\n\",\n",
    "    \"            'n_records': int(len(subset)),\\n\",\n",
    "    \"            'valence_mean': float(subset['valence'].mean()),\\n\",\n",
    "    \"            'valence_std': float(subset['valence'].std()),\\n\",\n",
    "    \"            'valence_median': float(subset['valence'].median()),\\n\",\n",
    "    \"            'arousal_mean': float(subset['arousal'].mean()),\\n\",\n",
    "    \"            'happiness_mean': float(subset['happiness.score'].mean()),\\n\",\n",
    "    \"            'happiness_std': float(subset['happiness.score'].std()),\\n\",\n",
    "    \"        }\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"═\\\" * 70)\\n\",\n",
    "    \"print(\\\"RIEPILOGO STATISTICHE ESTRATTE PER FASCIA\\\")\\n\",\n",
    "    \"print(\\\"═\\\" * 70)\\n\",\n",
    "    \"print(f\\\"{'Severità':<22} {'N.Paz':>6} {'V.Mean':>8} {'V.Std':>7} {'H.Mean':>7} {'H.Std':>7}\\\")\\n\",\n",
    "    \"print(\\\"─\\\" * 70)\\n\",\n",
    "    \"for sev, s in stats_by_severity.items():\\n\",\n",
    "    \"    print(f\\\"{sev:<22} {s['n_patients']:>6} {s['valence_mean']:>+8.3f} {s['valence_std']:>7.3f} \\\"\\n\",\n",
    "    \"          f\\\"{s['happiness_mean']:>7.2f} {s['happiness_std']:>7.3f}\\\")\"\n",
    "   ],\n",

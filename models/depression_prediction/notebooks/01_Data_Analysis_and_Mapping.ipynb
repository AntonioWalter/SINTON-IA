    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"---\\n\",\n",
    "    \"## 2. Il Modello Circomplesso di Russell: Mappatura Valence-Arousal\\n\",\n",
    "    \"\\n\",\n",
    "    \"Per unificare le diverse scale emotive dei dataset e renderle compatibili con i \\n\",\n",
    "    \"**10 stati d'animo × 10 intensità** di SINTON-IA, utilizziamo il **Modello Circomplesso\\n\",\n",
    "    \"dell'Affetto** di James A. Russell (1980).\\n\",\n",
    "    \"\\n\",\n",
    "    \"Ogni emozione viene proiettata su due assi:\\n\",\n",
    "    \"- **Valence** (Valenza): da -1 (molto negativo) a +1 (molto positivo)\\n\",\n",
    "    \"- **Arousal** (Attivazione): da -1 (passivo/letargico) a +1 (attivo/energetico)\\n\",\n",
    "    \"\\n\",\n",
    "    \"### Mappatura degli stati SINTON-IA\\n\",\n",
    "    \"I 10 stati d'animo dell'app vengono definiti come coordinate fisse nello spazio V-A,\\n\",\n",
    "    \"basate sulla letteratura psicologica (Russell, 1980; Posner et al., 2005).\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"id\": \"9bbcb0ad\",\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-03-11T20:21:03.833814300Z\",\n",
    "     \"start_time\": \"2026-03-11T20:21:02.837125800Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"# ═══════════════════════════════════════════════════════════════════\\n\",\n",
    "    \"# MAPPATURA SINTON-IA → VALENCE / AROUSAL  (Modello Circomplesso)\\n\",\n",
    "    \"# ═══════════════════════════════════════════════════════════════════\\n\",\n",
    "    \"# Coordinate basate su:\\n\",\n",
    "    \"#   - Russell, J.A. (1980). A circumplex model of affect.\\n\",\n",
    "    \"#   - Posner, J. et al. (2005). The circumplex model of affect.\\n\",\n",
    "    \"#   - Barrett, L.F. & Russell, J.A. (1999). The structure of current affect.\\n\",\n",
    "    \"\\n\",\n",
    "    \"SINTONIA_VALENCE_AROUSAL = {\\n\",\n",
    "    \"    # Stato d'animo     : (Valence, Arousal)\\n\",\n",
    "    \"    'Felice'            : ( 0.85,   0.60),\\n\",\n",
    "    \"    'Sereno'            : ( 0.70,  -0.20),\\n\",\n",
    "    \"    'Energico'          : ( 0.50,   0.90),\\n\",\n",
    "    \"    'Neutro'            : ( 0.00,   0.00),\\n\",\n",
    "    \"    'Stanco'            : (-0.20,  -0.75),\\n\",\n",
    "    \"    'Triste'            : (-0.80,  -0.40),\\n\",\n",
    "    \"    'Ansioso'           : (-0.55,   0.70),\\n\",\n",
    "    \"    'Arrabbiato'        : (-0.70,   0.80),\\n\",\n",
    "    \"    'Spaventato'        : (-0.65,   0.75),\\n\",\n",
    "    \"    'Confuso'           : (-0.30,   0.20),\\n\",\n",
    "    \"}\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"╔══════════════════════════════════════════════════════════╗\\\")\\n\",\n",
    "    \"print(\\\"║   MAPPATURA STATI D'ANIMO SINTON-IA → VALENCE/AROUSAL  ║\\\")\\n\",\n",
    "    \"print(\\\"╠══════════════════╤══════════╤══════════╤════════════════╣\\\")\\n\",\n",
    "    \"print(\\\"║ Stato d'animo    │ Valence  │ Arousal  │ Quadrante      ║\\\")\\n\",\n",
    "    \"print(\\\"╟──────────────────┼──────────┼──────────┼────────────────╢\\\")\\n\",\n",
    "    \"for name, (v, a) in SINTONIA_VALENCE_AROUSAL.items():\\n\",\n",
    "    \"    if v >= 0 and a >= 0:\\n\",\n",
    "    \"        quad = \\\"Alto-Positivo\\\"\\n\",\n",
    "    \"    elif v >= 0 and a < 0:\\n\",\n",
    "    \"        quad = \\\"Basso-Positivo\\\"\\n\",\n",
    "    \"    elif v < 0 and a >= 0:\\n\",\n",
    "    \"        quad = \\\"Alto-Negativo\\\"\\n\",\n",
    "    \"    else:\\n\",\n",
    "    \"        quad = \\\"Basso-Negativo\\\"\\n\",\n",
    "    \"    print(f\\\"║ {name:<16} │ {v:>+6.2f}   │ {a:>+6.2f}   │ {quad:<14} ║\\\")\\n\",\n",
    "    \"print(\\\"╚══════════════════╧══════════╧══════════╧════════════════╝\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Visualizzazione grafica nello spazio V-A\\n\",\n",
    "    \"fig, ax = plt.subplots(1, 1, figsize=(10, 10))\\n\",\n",
    "    \"ax.set_xlim(-1.2, 1.2)\\n\",\n",
    "    \"ax.set_ylim(-1.2, 1.2)\\n\",\n",
    "    \"ax.axhline(0, color='gray', linewidth=0.5, linestyle='--')\\n\",\n",
    "    \"ax.axvline(0, color='gray', linewidth=0.5, linestyle='--')\\n\",\n",
    "    \"\\n\",\n",
    "    \"colors = {\\n\",\n",
    "    \"    'Felice': '#FFD700', 'Sereno': '#87CEEB', 'Energico': '#FF6347',\\n\",\n",
    "    \"    'Neutro': '#C0C0C0', 'Stanco': '#8B8B83', 'Triste': '#4169E1',\\n\",\n",
    "    \"    'Ansioso': '#FF8C00', 'Arrabbiato': '#DC143C', 'Spaventato': '#9400D3',\\n\",\n",
    "    \"    'Confuso': '#DDA0DD'\\n\",\n",
    "    \"}\\n\",\n",
    "    \"\\n\",\n",
    "    \"for name, (v, a) in SINTONIA_VALENCE_AROUSAL.items():\\n\",\n",
    "    \"    ax.scatter(v, a, s=350, c=colors[name], edgecolors='black', linewidths=1.5, zorder=5)\\n\",\n",
    "    \"    ax.annotate(name, (v, a), textcoords=\\\"offset points\\\", xytext=(0, 15),\\n\",\n",
    "    \"                ha='center', fontsize=11, fontweight='bold')\\n\",\n",
    "    \"\\n\",\n",
    "    \"circle = plt.Circle((0, 0), 1, fill=False, linestyle=':', color='gray', linewidth=1)\\n\",\n",
    "    \"ax.add_patch(circle)\\n\",\n",
    "    \"ax.set_xlabel('← Valenza Negativa — Valenza Positiva →', fontsize=13)\\n\",\n",
    "    \"ax.set_ylabel('← Bassa Attivazione — Alta Attivazione →', fontsize=13)\\n\",\n",
    "    \"ax.set_title('Spazio Circomplesso di Russell: Mappatura SINTON-IA', fontsize=15, fontweight='bold')\\n\",\n",
    "    \"ax.set_aspect('equal')\\n\",\n",
    "    \"plt.tight_layout()\\n\",\n",
    "    \"plt.savefig(os.path.join(FIGURES_DIR, 'dp_valence_arousal_map.png'), dpi=150, bbox_inches='tight')\\n\",\n",
    "    \"plt.close()\\n\",\n",
    "    \"print(\\\"✅ Mappa Valence-Arousal salvata in docs/latex/figures/dp_valence_arousal_map.png\\\")\"\n",
    "   ],\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"name\": \"stdout\",\n",
    "     \"output_type\": \"stream\",\n",
    "     \"text\": [\n",
    "      \"╔══════════════════════════════════════════════════════════╗\\n\",\n",
    "      \"║   MAPPATURA STATI D'ANIMO SINTON-IA → VALENCE/AROUSAL  ║\\n\",\n",
    "      \"╠══════════════════╤══════════╤══════════╤════════════════╣\\n\",\n",
    "      \"║ Stato d'animo    │ Valence  │ Arousal  │ Quadrante      ║\\n\",\n",
    "      \"╟──────────────────┼──────────┼──────────┼────────────────╢\\n\",\n",
    "      \"║ Felice           │  +0.85   │  +0.60   │ Alto-Positivo  ║\\n\",\n",
    "      \"║ Sereno           │  +0.70   │  -0.20   │ Basso-Positivo ║\\n\",\n",
    "      \"║ Energico         │  +0.50   │  +0.90   │ Alto-Positivo  ║\\n\",\n",
    "      \"║ Neutro           │  +0.00   │  +0.00   │ Alto-Positivo  ║\\n\",\n",
    "      \"║ Stanco           │  -0.20   │  -0.75   │ Basso-Negativo ║\\n\",\n",
    "      \"║ Triste           │  -0.80   │  -0.40   │ Basso-Negativo ║\\n\",\n",
    "      \"║ Ansioso          │  -0.55   │  +0.70   │ Alto-Negativo  ║\\n\",\n",
    "      \"║ Arrabbiato       │  -0.70   │  +0.80   │ Alto-Negativo  ║\\n\",\n",
    "      \"║ Spaventato       │  -0.65   │  +0.75   │ Alto-Negativo  ║\\n\",\n",
    "      \"║ Confuso          │  -0.30   │  +0.20   │ Alto-Negativo  ║\\n\",\n",
    "      \"╚══════════════════╧══════════╧══════════╧════════════════╝\\n\",\n",
    "      \"✅ Mappa Valence-Arousal salvata in docs/latex/figures/dp_valence_arousal_map.png\\n\"\n",
    "     ]\n",
    "    }\n",
    "   ],\n",

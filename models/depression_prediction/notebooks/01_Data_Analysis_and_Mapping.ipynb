    "   \"source\": [\n",
    "    \"# ═══════════════════════════════════════════════════════════════\\n\",\n",
    "    \"# 5.3  TASSO DI DROPOUT / MISSING DATA PER FASCIA\\n\",\n",
    "    \"# ═══════════════════════════════════════════════════════════════\\n\",\n",
    "    \"# Calcoliamo quante risposte mancano rispetto al teorico massimo (14 gg × 3 periodi = 42)\\n\",\n",
    "    \"\\n\",\n",
    "    \"q_cols = [f'q{i}' for i in range(1, 15)] + ['q16', 'q46', 'q47']\\n\",\n",
    "    \"\\n\",\n",
    "    \"for sev in severities:\\n\",\n",
    "    \"    subset = df14[df14['severity'] == sev]\\n\",\n",
    "    \"    if len(subset) > 0:\\n\",\n",
    "    \"        total_possible = len(subset) * len(q_cols)\\n\",\n",
    "    \"        total_missing = subset[q_cols].isna().sum().sum()\\n\",\n",
    "    \"        missing_rate = total_missing / total_possible if total_possible > 0 else 0\\n\",\n",
    "    \"        stats_by_severity[sev]['missing_rate'] = float(missing_rate)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"\\\\n═\\\" * 60)\\n\",\n",

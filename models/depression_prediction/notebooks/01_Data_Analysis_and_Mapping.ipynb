    "   \"source\": [\n",
    "    \" # Analisi del Mood dettagliato\\n\",\n",
    "    \"if len(mood_df) > 0:\\n\",\n",
    "    \"    # Converti tipi\\n\",\n",
    "    \"    for col in ['happy', 'sad']:\\n\",\n",
    "    \"        mood_df[col] = pd.to_numeric(mood_df[col], errors='coerce')\\n\",\n",
    "    \"    \\n\",\n",
    "    \"    # Converti timestamp\\n\",\n",
    "    \"    mood_df['datetime'] = pd.to_datetime(mood_df['resp_time'], unit='s', errors='coerce')\\n\",\n",
    "    \"    \\n\",\n",
    "    \"    print(\\\"\\\\n═\\\" * 60)\\n\",\n",
    "    \"    print(\\\"STATISTICHE MOOD DETTAGLIATO\\\")\\n\",\n",
    "    \"    print(\\\"═\\\" * 60)\\n\",\n",

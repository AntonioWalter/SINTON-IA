    "    \"        print(f\\\"      {val}: {count} ({count/len(mood_df)*100:.1f}%)\\\")\\n\",\n",
    "    \"    \\n\",\n",
    "    \"    print(f\\\"\\\\n  Sad scale (1-4):\\\")\\n\",\n",

    "   \"source\": [\n",
    "    \"# ═══════════════════════════════════════════════════════════════\\n\",\n",
    "    \"# 5.2  MATRICE DI TRANSIZIONE EMOTIVA (Catena di Markov 1° ordine)\\n\",\n",
    "    \"# ═══════════════════════════════════════════════════════════════\\n\",\n",
    "    \"# Discretizziamo la valence in 5 livelli per calcolare le transizioni \\n\",\n",
    "    \"\\n\",\n",
    "    \"def discretize_valence(v):\\n\",\n",
    "    \"    \\\"\\\"\\\"Discretizza la valence in 5 categorie.\\\"\\\"\\\"\\n\",\n",
    "    \"    if v <= -0.6:\\n\",\n",
    "    \"        return 'Molto_Negativo'\\n\",\n",
    "    \"    elif v <= -0.2:\\n\",\n",
    "    \"        return 'Negativo'\\n\",\n",
    "    \"    elif v <= 0.2:\\n\",\n",
    "    \"        return 'Neutro'\\n\",\n",
    "    \"    elif v <= 0.6:\\n\",\n",
    "    \"        return 'Positivo'\\n\",\n",
    "    \"    else:\\n\",\n",
    "    \"        return 'Molto_Positivo'\\n\",\n",
    "    \"\\n\",\n",
    "    \"df14['valence_cat'] = df14['valence'].apply(lambda v: discretize_valence(v) if pd.notna(v) else None)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Calcola matrice di transizione per ogni utente, poi media\\n\",\n",
    "    \"transition_matrices = {}\\n\",\n",
    "    \"categories = ['Molto_Negativo', 'Negativo', 'Neutro', 'Positivo', 'Molto_Positivo']\\n\",\n",
    "    \"\\n\",\n",
    "    \"for sev in severities:\\n\",\n",
    "    \"    users = df14[df14['severity'] == sev]['user_id'].unique()\\n\",\n",
    "    \"    sev_transitions = np.zeros((5, 5))\\n\",\n",
    "    \"    \\n\",\n",
    "    \"    for uid in users:\\n\",\n",
    "    \"        user_data = df14[(df14['user_id'] == uid) & df14['valence_cat'].notna()].sort_values('time')\\n\",\n",
    "    \"        vals = user_data['valence_cat'].values\\n\",\n",
    "    \"        \\n\",\n",
    "    \"        for i in range(len(vals) - 1):\\n\",\n",
    "    \"            from_idx = categories.index(vals[i])\\n\",\n",
    "    \"            to_idx = categories.index(vals[i + 1])\\n\",\n",
    "    \"            sev_transitions[from_idx, to_idx] += 1\\n\",\n",
    "    \"    \\n\",\n",
    "    \"    # Normalizza righe\\n\",\n",
    "    \"    row_sums = sev_transitions.sum(axis=1, keepdims=True)\\n\",\n",
    "    \"    row_sums[row_sums == 0] = 1\\n\",\n",
    "    \"    transition_matrices[sev] = (sev_transitions / row_sums).tolist()\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"\\\\n═\\\" * 60)\\n\",\n",
    "    \"print(\\\"MATRICE DI TRANSIZIONE — ESEMPIO: SEVERA (20-27)\\\")\\n\",\n",
    "    \"print(\\\"═\\\" * 60)\\n\",\n",
    "    \"if 'Severa (20-27)' in transition_matrices:\\n\",\n",
    "    \"    mat = np.array(transition_matrices['Severa (20-27)'])\\n\",\n",
    "    \"    tm_df = pd.DataFrame(mat, index=categories, columns=categories)\\n\",\n",
    "    \"    print(tm_df.round(3).to_string())\\n\",\n",
    "    \"else:\\n\",\n",
    "    \"    print(\\\"Nessun paziente con severità Severa nel dataset.\\\")\"\n",
    "   ],\n",

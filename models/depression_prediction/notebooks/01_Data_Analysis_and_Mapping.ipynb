    "   \"source\": [\n",
    "    \"# Mappatura happiness.score (0-4) del 14-day → Valence\\n\",\n",
    "    \"# Nel 14-day dataset, happiness.score: 0=molto infelice → 4=molto felice\\n\",\n",
    "    \"\\n\",\n",
    "    \"def happiness_score_to_VA(score):\\n\",\n",
    "    \"    \\\"\\\"\\\"\\n\",\n",
    "    \"    Converte happiness.score (0-4) → (Valence, Arousal).\\n\",\n",
    "    \"    Il 14-day dataset ha solo un asse di felicità, quindi:\\n\",\n",
    "    \"    - Valence = mappatura lineare [0,4] → [-1,1]\\n\",\n",
    "    \"    - Arousal = stima basata sulla distanza dal neutro\\n\",\n",
    "    \"    \\\"\\\"\\\"\\n\",\n",
    "    \"    valence = (score / 4) * 2 - 1   # 0→-1, 2→0, 4→+1\\n\",\n",
    "    \"    arousal = abs(valence) * 0.5 - 0.25  # Estremi emotivi = più attivazione\\n\",\n",
    "    \"    return valence, arousal\\n\",\n",
    "    \"\\n\",\n",
    "    \"df14['valence'], df14['arousal'] = zip(*df14['happiness.score'].apply(\\n\",\n",
    "    \"    lambda s: happiness_score_to_VA(s) if pd.notna(s) else (np.nan, np.nan)))\\n\",\n",

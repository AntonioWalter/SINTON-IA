    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"### 3.3 Mappatura Student Life → Valence-Arousal\\n\",\n",
    "    \"\\n\",\n",
    "    \"Trasformiamo i punteggi `happy` e `sad` del dataset originale nello spazio V-A:\\n\",\n",
    "    \"- **Valence** = (happy_norm - sad_norm), dove ogni score è normalizzato [0,1]\\n\",\n",
    "    \"- **Arousal** = derivato dall'intensità complessiva dell'emozione\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"id\": \"cb2d49cd\",\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-03-11T20:21:09.383328700Z\",\n",
    "     \"start_time\": \"2026-03-11T20:21:08.946931800Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"# ═══════════════════════════════════════════════════════════════\\n\",\n",
    "    \"# 3.3  PROIEZIONE STUDENT LIFE → VALENCE-AROUSAL\\n\",\n",
    "    \"# ═══════════════════════════════════════════════════════════════\\n\",\n",
    "    \"\\n\",\n",
    "    \"def student_life_to_VA(happy, sad):\\n\",\n",
    "    \"    \\\"\\\"\\\"\\n\",\n",
    "    \"    Proietta i punteggi happy (1-4) e sad (1-4) del Student Life\\n\",\n",
    "    \"    nello spazio Valence-Arousal.\\n\",\n",
    "    \"    \\n\",\n",
    "    \"    Logica basata su Barrett & Russell (1999):\\n\",\n",
    "    \"    - Valence: differenza normalizzata tra felicità e tristezza\\n\",\n",
    "    \"    - Arousal: intensità emotiva complessiva (più è intenso, più è attivo)\\n\",\n",
    "    \"    \\\"\\\"\\\"\\n\",\n",
    "    \"    # Normalizzazione [0, 1]\\n\",\n",
    "    \"    h_norm = (happy - 1) / 3  # 1→0, 4→1\\n\",\n",
    "    \"    s_norm = (sad - 1) / 3    # 1→0, 4→1\\n\",\n",
    "    \"    \\n\",\n",
    "    \"    # Valence: asse positivo-negativo\\n\",\n",
    "    \"    valence = h_norm - s_norm  # Range: [-1, 1]\\n\",\n",
    "    \"    \\n\",\n",
    "    \"    # Arousal: intensità emotiva (alta felicità O alta tristezza = alta attivazione)\\n\",\n",
    "    \"    arousal = max(h_norm, s_norm) * 2 - 1  # Più l'emozione è forte, maggiore l'arousal\\n\",\n",
    "    \"    # Correggiamo: tristezza intensa abbassa leggermente l'arousal\\n\",\n",
    "    \"    if s_norm > h_norm:\\n\",\n",
    "    \"        arousal = arousal * 0.7  # La tristezza tende alla passività\\n\",\n",
    "    \"    \\n\",\n",
    "    \"    return valence, arousal\\n\",\n",
    "    \"\\n\",\n",
    "    \"if len(mood_df) > 0:\\n\",\n",
    "    \"    mood_df['valence'], mood_df['arousal'] = zip(*mood_df.apply(\\n\",\n",
    "    \"        lambda r: student_life_to_VA(r['happy'], r['sad']) \\n\",\n",
    "    \"        if pd.notna(r['happy']) and pd.notna(r['sad']) else (np.nan, np.nan), axis=1))\\n\",\n",
    "    \"    \\n\",\n",
    "    \"    # Unisci con PHQ-9 per analisi per fasce di severità\\n\",\n",
    "    \"    phq9_pre = phq9_scored[phq9_scored['type'] == 'pre'][['uid', 'phq9_total', 'severity']]\\n\",\n",
    "    \"    mood_with_phq = mood_df.merge(phq9_pre, on='uid', how='left')\\n\",\n",
    "    \"    \\n\",\n",
    "    \"    print(\\\"═\\\" * 60)\\n\",\n",
    "    \"    print(\\\"ANALISI VALENCE-AROUSAL PER SEVERITÀ PHQ-9\\\")\\n\",\n",
    "    \"    print(\\\"═\\\" * 60)\\n\",\n",
    "    \"    for sev in ['Minima (0-4)', 'Lieve (5-9)', 'Moderata (10-14)', 'Mod. Severa (15-19)', 'Severa (20-27)']:\\n\",\n",
    "    \"        subset = mood_with_phq[mood_with_phq['severity'] == sev]\\n\",\n",
    "    \"        if len(subset) > 0:\\n\",\n",
    "    \"            print(f\\\"\\\\n▶ {sev} ({len(subset)} check-in)\\\")\\n\",\n",
    "    \"            print(f\\\"  Valence media: {subset['valence'].mean():+.3f}\\\")\\n\",\n",
    "    \"            print(f\\\"  Arousal medio: {subset['arousal'].mean():+.3f}\\\")\\n\",\n",
    "    \"            print(f\\\"  Valence std:   {subset['valence'].std():.3f}\\\")\"\n",
    "   ],\n",

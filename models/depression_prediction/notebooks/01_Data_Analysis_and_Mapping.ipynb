    "    \"# ═══════════════════════════════════════════════════════════════\\n\",\n",
    "    \"# 5.4  DURATA MEDIA STREAK NEGATIVE\\n\",\n",
    "    \"# ═══════════════════════════════════════════════════════════════\\n\",\n",
    "    \"# Analizziamo per quanto tempo consecutivo un paziente rimane in zona negativa\\n\",\n",
    "    \"\\n\",\n",
    "    \"streak_stats = {}\\n\",\n",
    "    \"for sev in severities:\\n\",\n",
    "    \"    users = df14[df14['severity'] == sev]['user_id'].unique()\\n\",\n",
    "    \"    all_streaks = []\\n\",\n",
    "    \"    \\n\",\n",
    "    \"    for uid in users:\\n\",\n",
    "    \"        user_data = df14[(df14['user_id'] == uid) & df14['valence'].notna()].sort_values('time')\\n\",\n",
    "    \"        negative = (user_data['valence'] < 0).values\\n\",\n",
    "    \"        \\n\",\n",
    "    \"        current_streak = 0\\n\",\n",
    "    \"        for is_neg in negative:\\n\",\n",
    "    \"            if is_neg:\\n\",\n",
    "    \"                current_streak += 1\\n\",\n",
    "    \"            else:\\n\",\n",
    "    \"                if current_streak > 0:\\n\",\n",
    "    \"                    all_streaks.append(current_streak)\\n\",\n",
    "    \"                current_streak = 0\\n\",\n",
    "    \"        if current_streak > 0:\\n\",\n",
    "    \"            all_streaks.append(current_streak)\\n\",\n",
    "    \"    \\n\",\n",
    "    \"    if all_streaks:\\n\",\n",
    "    \"        streak_stats[sev] = {\\n\",\n",

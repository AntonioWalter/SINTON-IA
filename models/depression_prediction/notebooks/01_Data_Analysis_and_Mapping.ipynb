    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"### 3.2 Mood JSON — Check-in Emotivi degli Studenti\\n\",\n",
    "    \"\\n\",\n",
    "    \"Ogni file `Mood_uXX.json` contiene registrazioni con:\\n\",\n",
    "    \"- `happy` (1-4): intensità felicità (1=un po', 4=estremamente)\\n\",\n",
    "    \"- `sad` (1-4): intensità tristezza\\n\",\n",
    "    \"- `happyornot` (1=Sì, 2=No): flag binario felicità\\n\",\n",
    "    \"- `sadornot` (1=Sì, 2=No): flag binario tristezza\\n\",\n",
    "    \"- `resp_time`: timestamp UNIX\\n\",\n",
    "    \"- `location`: coordinate GPS\\n\",\n",
    "    \"\\n\",\n",
    "    \"**Mood 1** contiene `tomorrow` (1=happy, 2=stressed, 3=tired): previsione del giorno dopo.\\n\",\n",
    "    \"**Mood 2** contiene `how` (1=happy, 2=stressed, 3=tired): stato attuale.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"id\": \"4114e498\",\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-03-11T20:21:08.628724200Z\",\n",
    "     \"start_time\": \"2026-03-11T20:21:08.109094700Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"# ═══════════════════════════════════════════════════════════════\\n\",\n",
    "    \"# 3.2  CARICAMENTO MOOD JSON (Student Life)\\n\",\n",
    "    \"# ═══════════════════════════════════════════════════════════════\\n\",\n",
    "    \"\\n\",\n",
    "    \"def load_mood_folder(folder_path, mood_type='mood'):\\n\",\n",
    "    \"    \\\"\\\"\\\"Carica tutti i file JSON di una cartella Mood e li concatena.\\\"\\\"\\\"\\n\",\n",
    "    \"    all_records = []\\n\",\n",
    "    \"    pattern = os.path.join(folder_path, '*.json')\\n\",\n",
    "    \"    \\n\",\n",
    "    \"    for filepath in sorted(glob.glob(pattern)):\\n\",\n",
    "    \"        filename = os.path.basename(filepath)\\n\",\n",
    "    \"        # Estrai user_id dal nome file (es: \\\"Mood_u00.json\\\" -> \\\"u00\\\")\\n\",\n",
    "    \"        uid = filename.split('_')[-1].replace('.json', '')\\n\",\n",
    "    \"        \\n\",\n",
    "    \"        try:\\n\",\n",
    "    \"            with open(filepath, 'r') as f:\\n\",\n",
    "    \"                data = json.load(f)\\n\",\n",
    "    \"            \\n\",\n",
    "    \"            if isinstance(data, list):\\n\",\n",
    "    \"                for record in data:\\n\",\n",
    "    \"                    record['uid'] = uid\\n\",\n",
    "    \"                    record['mood_type'] = mood_type\\n\",\n",
    "    \"                    all_records.append(record)\\n\",\n",
    "    \"        except (json.JSONDecodeError, Exception):\\n\",\n",
    "    \"            pass\\n\",\n",
    "    \"    \\n\",\n",
    "    \"    return pd.DataFrame(all_records)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Caricamento dei 3 tipi di Mood\\n\",\n",
    "    \"mood_df = load_mood_folder(os.path.join(RAW_DIR, 'studentlife_mood_detailed'), 'mood_detailed')\\n\",\n",
    "    \"mood1_df = load_mood_folder(os.path.join(RAW_DIR, 'studentlife_mood_prediction'), 'mood_prediction')\\n\",\n",
    "    \"mood2_df = load_mood_folder(os.path.join(RAW_DIR, 'studentlife_mood_current'), 'mood_current')\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"═\\\" * 60)\\n\",\n",
    "    \"print(\\\"RIEPILOGO MOOD DATA (Student Life)\\\")\\n\",\n",
    "    \"print(\\\"═\\\" * 60)\\n\",\n",
    "    \"print(f\\\"\\\\n▶ Mood (dettagliato - happy/sad scale):  {len(mood_df):>6} record, {mood_df['uid'].nunique():>3} studenti\\\")\\n\",\n",
    "    \"print(f\\\"▶ Mood 1 (previsione domani):             {len(mood1_df):>6} record, {mood1_df['uid'].nunique():>3} studenti\\\")\\n\",\n",
    "    \"print(f\\\"▶ Mood 2 (stato attuale):                 {len(mood2_df):>6} record, {mood2_df['uid'].nunique():>3} studenti\\\")\"\n",
    "   ],\n",
